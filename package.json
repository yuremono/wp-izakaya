{
  "name": "portfolio-corporate-theme",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass assets/theme.scss assets/theme.css --style=expanded --no-source-map && sass assets/tailwind.scss assets/tailwind.css --style=expanded --no-source-map",
    "build:js": "esbuild assets/src/mindmap-front.ts --bundle --format=iife --outfile=assets/mindmap-runtime.js --minify",
    "deploy": "bash tools/deploy.sh",
    "deploy:prod": "bash tools/deploy.sh --delete --import-xml",
    "watch": "sass --watch assets/theme.scss:assets/theme.css assets/tailwind.scss:assets/tailwind.css --style=expanded --no-source-map"
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.0",
    "sass": "^1.83.0",
    "tailwindcss": "^3.4.19"
  }
}
